CompileFlags:
  # Mirror the CMake build flags so the language server agrees with the compiler.
  # CompilationDatabase tells clangd where to find compile_commands.json
  # (generated by CMake when CMAKE_EXPORT_COMPILE_COMMANDS is ON).
  CompilationDatabase: out/build/release-linux
  Add: [-std=c++23, -I/home/alex/Projects/path-tracer/external] 
