#version 460 core
layout(local_size_x = 8, local_size_y = 8) in;
#include "common/path_state.glsl"
#include "common/queue.glsl"
#include "common/rng.glsl"
#include "common/scene_buffers.glsl"

layout(binding = 5) uniform sampler2D gbuf_pos_matid_tex;
layout(binding = 6) uniform sampler2D gbuf_normal_tex;
layout(location = 0) uniform ivec2 image_size;
layout(location = 1) uniform int frame_index;
layout(location = 3) uniform int time;

void main() {
    ivec2 px = ivec2(gl_GlobalInvocationID.xy);
    if (px.x >= image_size.x || px.y >= image_size.y) return;
    uint pid = uint(px.y * image_size.x + px.x);

    vec4 pm = texelFetch(gbuf_pos_matid_tex, px, 0);
    vec3 n = texelFetch(gbuf_normal_tex, px, 0).xyz;

    // Initialize *every* pixel's PathState. Pixels that miss the gbuffer
    // simply don't enter ray_queue and contribute zero radiance.
    states[pid].throughput = vec3(1);
    states[pid].radiance = vec3(0);
    states[pid].pixel_idx = pid;
    states[pid].bounce = 0;
    states[pid].rng_state = init_rng(pid, frame_index);
    states[pid].flags = FLAG_FRONT_FACE; // raster pass renders front faces only

    // Sky test: gbuffer normal of length zero means no primitive was rasterized.
    // Any real hit has a unit normal.
    if (dot(n, n) < 0.5) {
        return; // path stays out of every queue → contributes zero radiance
    }

    uint matid = floatBitsToUint(pm.w);
    states[pid].hit_point = pm.xyz;
    states[pid].hit_normal = normalize(n);
    states[pid].hit_matid = matid;
    // Camera-to-hit direction. shade_metal/dielectric reflect/refract `ray_dir` on the
    // first bounce, so it must be initialized — the gbuffer-fed primary "ray" is the view ray.
    states[pid].ray_dir = normalize(pm.xyz - camera_position);

    // ray_queue_push(pid);
    // Skip the first trace by pushing straight to the per-material hit queue.
    // Subsequent bounces go through trace.comp
    float t = mats[matid].type;
    if (t == MAT_LAMBERTIAN) hit_lambertian_push(pid);
    else if (t == MAT_METAL) hit_metal_push(pid);
    else if (t == MAT_DIELECTRIC) hit_dielectric_push(pid);
    else hit_emissive_push(pid);
}
